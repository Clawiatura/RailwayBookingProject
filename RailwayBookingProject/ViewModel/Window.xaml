<Window x:Class="TravelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Travel App" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="История поездок">
                <DataGrid x:Name="TripsDataGrid" ItemsSource="{Binding Trips}" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <!-- Добавьте столбцы для данных о поездках -->
                        <DataGridTextColumn Header="Место назначения" Binding="{Binding Destination}" />
                        <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate}" />
                        <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate}" />
                        <!-- ... другие столбцы -->
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Бронирование">
                <!-- Элементы управления для бронирования -->
                <StackPanel>
                    <Label Content="Место назначения:" />
                    <TextBox x:Name="DestinationTextBox" Text="{Binding BookingDestination}" />
                    <Label Content="Дата начала:" />
                    <DatePicker x:Name="StartDatePicker" SelectedDate="{Binding BookingStartDate}" />
                    <Label Content="Дата окончания:" />
                    <DatePicker x:Name="EndDatePicker" SelectedDate="{Binding BookingEndDate}" />
                    <!-- ... другие поля для бронирования -->
                    <Button Content="Забронировать" Command="{Binding BookTripCommand}" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Личные данные">
                <!-- Элементы управления для личных данных -->
                <StackPanel>
                    <Label Content="Имя:" />
                    <TextBox Text="{Binding FirstName}" />
                    <Label Content="Фамилия:" />
                    <TextBox Text="{Binding LastName}" />
                    <!-- ... другие поля для личных данных -->
                    <Button Content="Сохранить" Command="{Binding SavePersonalDataCommand}" />

                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

